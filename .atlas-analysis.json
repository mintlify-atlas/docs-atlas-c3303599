  "keyFeatures": [
    "Real-time cryptocurrency arbitrage detection across spot and futures markets",
    "AI-powered autonomous trading with multi-agent decision system",
    "Advanced technical analysis with 50+ indicators",
    "Quest-based autonomous operation scheduler with Redis coordination",
    "Comprehensive risk management with daily loss limits and circuit breakers",
    "Telegram bot for remote monitoring and control",
    "Multi-exchange support via CCXT integration",
    "Native CLI gateway for service orchestration",
    "WebSocket market data streaming",
    "Paper trading simulation and backtesting"
  ],
  "publicApiSurface": [
    "GET /health - System health status",
    "GET /ready - Readiness probe",
    "GET /api/v1/market/tickers - Real-time ticker data",
    "GET /api/v1/market/orderbook - Order book snapshots",
    "GET /api/v1/arbitrage/opportunities - Spot arbitrage opportunities",
    "GET /api/v1/futures/opportunities - Futures funding arbitrage",
    "GET /api/v1/analysis/signals - Trading signals with indicators",
    "POST /api/v1/trading/place_order - Execute trading order",
    "POST /api/v1/trading/cancel_order - Cancel open order",
    "GET /api/v1/trading/positions - List tracked positions",
    "POST /api/v1/trading/liquidate - Close position",
    "GET /api/v1/autonomous/quests - List autonomous quests",
    "POST /api/v1/autonomous/quests - Create new quest",
    "GET /api/v1/autonomous/budget - Budget status",
    "GET /api/v1/exchanges - List configured exchanges",
    "./bin/neuratrade gateway start - Start all services",
    "./bin/neuratrade gateway stop - Stop all services",
    "./bin/neuratrade gateway status - Check service status",
    "./bin/neuratrade exchanges list - List available exchanges",
    "./bin/neuratrade ai models - List AI models"
  ]
